# ============================================================
# Social Media Automation Platform — API Keys Example
# ============================================================
# Copy this file to .env in the project root and fill in values.
# NEVER commit the real .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Twitter / X
# ------------------------------------------------------------
# Create an app at: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# ------------------------------------------------------------
# Instagram (via Meta Graph API)
# ------------------------------------------------------------
# Requires a Facebook Page connected to an Instagram Business account
# Generate tokens at: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ------------------------------------------------------------
# Facebook
# ------------------------------------------------------------
# Page access token (long-lived)
# https://developers.facebook.com/docs/facebook-login/access-tokens
FACEBOOK_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# ------------------------------------------------------------
# LinkedIn
# ------------------------------------------------------------
# OAuth 2.0 — generate via LinkedIn Developer Portal
# https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_ORGANIZATION_ID=urn:li:organization:YOUR_ORG_ID
LINKEDIN_PERSON_ID=urn:li:person:YOUR_PERSON_URN

# ------------------------------------------------------------
# YouTube
# ------------------------------------------------------------
# OAuth 2.0 — generate via Google Cloud Console
# https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# ------------------------------------------------------------
# Google Ads
# ------------------------------------------------------------
# https://ads.google.com/intl/en/home/tools/manager-accounts/
# Developer token: https://developers.google.com/google-ads/api/docs/first-call/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Comma-separated customer IDs for campaign monitoring
GOOGLE_ADS_CUSTOMER_IDS=1234567890,0987654321

# ------------------------------------------------------------
# Facebook Ads (Meta Marketing API)
# ------------------------------------------------------------
# SEPARATE from organic Facebook posting above.
# Requires a System User token from Meta Business Manager for
# non-expiring automation. Do NOT use a personal user token here.
# https://developers.facebook.com/docs/marketing-apis
FACEBOOK_ADS_ACCESS_TOKEN=your_system_user_access_token_here
FACEBOOK_ADS_ACCOUNT_ID=act_your_ad_account_id_here

# ------------------------------------------------------------
# TikTok (OPTIONAL — requires manual API approval from TikTok)
# ------------------------------------------------------------
# Apply at: https://developers.tiktok.com/
# Approval takes 2-7 days and is NOT guaranteed.
# Leave blank if you do not have TikTok API access yet.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_OPEN_ID=
